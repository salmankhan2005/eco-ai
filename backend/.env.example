# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# JWT Secret - REQUIRED for production, use a strong random string (32+ chars)
JWT_SECRET=your-strong-random-secret-key-here

# Admin API Key (optional, if empty admin routes are open in dev mode)
ADMIN_API_KEY=

# CORS Origins for production (comma-separated)
CORS_ORIGINS=https://your-frontend.vercel.app,https://your-admin.vercel.app
